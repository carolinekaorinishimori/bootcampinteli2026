# Configuração da OpenAI para análise de respostas por IA (lado do cliente).
# Copie este arquivo para ".env" e preencha os valores.
# AVISO: a chamada é feita direto do navegador e expõe a chave. Use apenas em
# ambiente controlado/demo. Para produção, prefira um proxy de servidor.

VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4o-mini
